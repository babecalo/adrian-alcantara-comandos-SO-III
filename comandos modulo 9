practica 5

nano instalar_notepad.yml

---
- name: Instalar Notepad++ en Windows
  hosts: win
  tasks:
    - name: Paso 1 - Descargar el instalador de Notepad++
      win_get_url:
        url: https://github.com/notepad-plus-plus/notepad-plus-plus/releases/download/v8.6.4/npp.8.6.4.Installer.x64.exe
        dest: C:\npp_installer.exe

    - name: Paso 2 - Instalar Notepad++ silenciosamente
      win_package:
        path: C:\npp_installer.exe
        arguments: /S
        state: present

ansible-playbook instalar_notepad.yml

{el linux}

nano instalar_nginx.yml

---
- name: Instalar y arrancar NGINX en Linux
  hosts: linux
  become: yes
  tasks:
    - name: Paso 1 - Instalar el paquete NGINX
      apt:
        name: nginx
        state: present
        update_cache: yes

    - name: Paso 2 - Asegurar que el servicio NGINX este encendido
      service:
        name: nginx
        state: started
        enabled: yes

ansible-playbook instalar_nginx.yml
